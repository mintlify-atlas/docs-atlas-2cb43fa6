  "keyFeatures": [
    "Zero external dependencies — uses only the Go standard library",
    "Feedforward layers: Affine, BatchNorm, Dropout, ReLU, Sigmoid, Softmax",
    "Recurrent layers: RNN, LSTM, GRU, BiLSTM with time-step variants",
    "Attention mechanism layers for sequence-to-sequence models",
    "Pre-built models: MLP, CBOW, RNNLM, Seq2Seq, PeekySeq2Seq, AttentionSeq2Seq",
    "Optimizers: SGD, Momentum, AdaGrad, Adam with hook support (WeightDecay, GradsClipping)",
    "Reinforcement learning agents: Q-Learning, SARSA, Monte Carlo, DQN",
    "Model persistence via gob encoding (Save/Load params)",
    "Built-in datasets: MNIST, Penn Treebank (PTB), arithmetic sequence"
  ],
  "publicApiSurface": [
    "model.NewMLP(*MLPConfig) *MLP",
    "model.NewSequential([]Layer, Source) *Sequential",
    "model.NewSeq2Seq / NewPeekySeq2Seq / NewAttentionSeq2Seq",
    "model.NewRNNLM / NewLSTMLM / NewGRULM / NewRNNLMGen",
    "model.NewCBOW / NewCBOWNegativeSampling",
    "model.NewQNet",
    "model.Save(filename, params) / model.Load(filename)",
    "trainer.New(Model, Optimizer) *Trainer",
    "trainer.Trainer.Fit(*Input)",
    "trainer.Accuracy(y, t matrix.Matrix) float64",
    "optimizer.SGD / Momentum / AdaGrad / Adam",
    "optimizer.Hook (WeightDecay, GradsClipping)",
    "layer.Affine / BatchNorm / Dropout / ReLU / Sigmoid / Softmax / SoftmaxWithLoss",
    "layer.RNN / LSTM / GRU / TimeLSTM / TimeGRU / TimeBiLSTM",
    "layer.Attention / AttentionWeight / WeightSum / TimeAttention",
    "layer.Embedding / TimeEmbedding / EmbeddingDot / NegativeSamplingLoss",
    "activation.ReLU / Sigmoid / Softmax / Tanh / Step / Identity",
    "loss.CrossEntropyError / MeanSquaredError / SumSquaredError",
    "weight.He / Xavier / Glorot / Std",
    "agent.Agent / DQNAgent / QLearning / SARSA / MonteCarlo",
    "math/matrix.Matrix (New, Zero, One, Randn, MatMul, ...)",
    "dataset/mnist.Load / Normalize / OneHot"
  ]
}
